# =============================================================================
# GreenTech Intelligence - Variables d'Environnement
# Copier ce fichier vers .env et modifier les valeurs
# =============================================================================

# === Application ===
APP_NAME=GreenTech Intelligence
APP_ENV=development
DEBUG=true
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_STRING_IN_PRODUCTION

# === Database PostgreSQL ===
# Utilisateur admin (DDL, init schema) - utilisé par Docker et migrations
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=greentech
POSTGRES_PASSWORD=greentech_dev_password
POSTGRES_DB=greentech_db

# Utilisateur applicatif (DML seulement) - utilisé par l'API FastAPI
POSTGRES_APP_USER=greentech_app
POSTGRES_APP_PASSWORD=greentech_app_password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_APP_USER}:${POSTGRES_APP_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# === MinIO (Stockage Objet S3-compatible) ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_RAW=raw-data
MINIO_BUCKET_CLEAN=clean-data
MINIO_BUCKET_MODELS=models

# === MLflow ===
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=greentech-classification

# === Hugging Face ===
HUGGINGFACE_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXX
# Cloud : Qwen3-4B-Instruct-2507 (Apache-2.0, servi par les HF Inference
# Providers, licence permissive). Utilise pour les resumes, le LLM judge
# de classification Green IT, et toute sollicitation LLM hors entrainement.
HUGGINGFACE_MODEL_SUMMARIZER=Qwen/Qwen3-4B-Instruct-2507
HUGGINGFACE_MODEL_GREEN_SUMMARIZER=Qwen/Qwen3-4B-Instruct-2507
HUGGINGFACE_MODEL_CLASSIFIER=microsoft/deberta-v3-base
HUGGINGFACE_MODEL_CLASSIFIER_LLM=Qwen/Qwen3-4B-Instruct-2507
# Modele de base utilise pour l'entrainement LoRA du classifieur Green IT
# (remplace `meta-llama/Llama-3.2-3B`). `Qwen/Qwen3-4B` (26 juillet 2025) est
# le LLM texte officiel 4B d'Alibaba, dense, multilingue natif (FR/EN/DE/ES/ZH),
# compatible RX 7900 XTX 24 Go en BF16 et libre de license (Apache-2.0,
# pas de demande d'acces gated). A NE PAS confondre avec `Qwen/Qwen3.5-4B`
# qui est un VLM (image-text-to-text) incompatible avec ROCm sans
# flash-linear-attention.
HUGGINGFACE_MODEL_TRAINER_BASE=Qwen/Qwen3-4B
# Meme modele utilise comme baseline (evaluation zero-shot sans fine-tuning)
# pour mesurer le gain apporte par le LoRA K-fold.
HUGGINGFACE_MODEL_BASELINE=Qwen/Qwen3-4B
# Encoder concurrent du benchmark equitable B4 (avril-mai 2026).
# `microsoft/mdeberta-v3-base` (multilingue, 278M params, encoder-only) est mis
# en competition avec `Qwen/Qwen3-4B` (decoder generatif) pour selectionner le
# meilleur classifieur Green IT sur dataset bilingue EN/FR. mDeBERTa est retenu
# (et pas `deberta-v3-base` EN-only) parce que 25.25 % du dataset est en FR.
HUGGINGFACE_MODEL_ENCODER_BASE=microsoft/mdeberta-v3-base
# Longueur max de sequence (tokens) lors de l'entrainement : 512 couvre la
# majorite des articles et divise par 4 la consommation memoire de l'attention
# par rapport a 1024 - indispensable pour un LoRA stable sur 24 Go de VRAM.
TRAINER_MAX_LENGTH=512
# Fallback local n1 : Qwen2.5-3B (~6 Go FP16, tient sur la plupart des GPU).
HUGGINGFACE_MODEL_LOCAL_FALLBACK=Qwen/Qwen2.5-3B-Instruct
# Fallback local n2 (lightweight) : auto-active par llm_local.py si la
# RAM/VRAM est insuffisante pour le 3B (~3 Go FP16, compatible CPU).
HUGGINGFACE_MODEL_LOCAL_FALLBACK_LIGHTWEIGHT=Qwen/Qwen2.5-1.5B-Instruct

# === API Configuration ===
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === JWT Authentication ===
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# === Celery / Redis (file d'attente analyses /analyze) ===
# Redis sert a la fois de broker (DB 0) et de result backend (DB 1) pour
# Celery. Le worker doit etre lance separement de l'API :
#   uv run celery -A greentech.api.celery_app worker --pool=solo --loglevel=info
# Dans Docker, le service `celery-worker` (profile=full) s'en charge.
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Retention des resultats Celery dans Redis (en secondes). 24h par defaut.
CELERY_RESULT_EXPIRES=86400
# Timeout dur d'execution d'une tache (en secondes). 10 min par defaut.
CELERY_TASK_TIME_LIMIT=600

# === Monitoring ===
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
# Alertmanager (port 9093) : mode "log only" par defaut, aucune variable d'env
# requise. Alertmanager n'interpole PAS les variables d'env dans son YAML
# (limitation upstream), donc pour activer un webhook Discord il faut copier
# `config/alertmanager/alertmanager.discord.example.yml` vers `alertmanager.yml`
# et y inserer le webhook reel, puis `docker compose restart alertmanager`.

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Data Collection ===
SCRAPING_USER_AGENT=GreenTech-Bot/1.0 (+https://github.com/YOUR_USERNAME/greentech-intelligence)
SCRAPING_DELAY_SECONDS=2

# --- APIs d'articles (sources REST/JSON) ---
# NewsData.io (LEGACY - source desactivee depuis avril 2026 car free tier
# tronque le contenu avec le placeholder "ONLY AVAILABLE IN PAID PLANS")
API_NEWS_KEY=YOUR_NEWS_API_KEY_HERE
# The Guardian Open Platform (source REST/JSON principale)
# Tier Developer : 5000 req/jour, 12 req/s, usage non-commercial uniquement
# Obtention gratuite et immediate : https://open-platform.theguardian.com/access/
GUARDIAN_API_KEY=YOUR_GUARDIAN_API_KEY_HERE
# Dev.to / Forem API : pas de cle requise en lecture publique (laisser vide)
DEVTO_API_KEY=
# Crossref API Polite Pool : email de contact publie dans le User-Agent.
# Non sensible. Fournir un contact permet a Crossref de prioriser nos
# requetes avec une latence stable. Laisser vide pour passer sur le
# pool public (plus lent mais fonctionnel).
# Doc: https://www.crossref.org/documentation/retrieve-metadata/rest-api/tips-for-using-the-crossref-rest-api/
CROSSREF_MAILTO=

# === Green IT / CodeCarbon ===
CODECARBON_ENABLED=true
CODECARBON_OUTPUT_DIR=./logs/carbon

# === DVC Remote ===
DVC_REMOTE_URL=s3://clean-data
DVC_REMOTE_ENDPOINT=http://localhost:9000
