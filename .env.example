# =============================================================================
# GreenTech Intelligence - Variables d'Environnement
# Copier ce fichier vers .env et modifier les valeurs
# =============================================================================

# === Application ===
APP_NAME=GreenTech Intelligence
APP_ENV=development
DEBUG=true
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_STRING_IN_PRODUCTION

# === Database PostgreSQL ===
# Utilisateur admin (DDL, init schema) - utilisé par Docker et migrations
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=greentech
POSTGRES_PASSWORD=greentech_dev_password
POSTGRES_DB=greentech_db

# Utilisateur applicatif (DML seulement) - utilisé par l'API FastAPI
POSTGRES_APP_USER=greentech_app
POSTGRES_APP_PASSWORD=greentech_app_password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_APP_USER}:${POSTGRES_APP_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# === MinIO (Stockage Objet S3-compatible) ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_RAW=raw-data
MINIO_BUCKET_CLEAN=clean-data
MINIO_BUCKET_MODELS=models

# === MLflow ===
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=greentech-classification

# === Hugging Face ===
HUGGINGFACE_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXX
HUGGINGFACE_MODEL_SUMMARIZER=facebook/bart-large-cnn
HUGGINGFACE_MODEL_CLASSIFIER=microsoft/deberta-v3-base

# === API Configuration ===
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# === JWT Authentication ===
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# === Monitoring ===
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Data Collection ===
SCRAPING_USER_AGENT=GreenTech-Bot/1.0 (+https://github.com/YOUR_USERNAME/greentech-intelligence)
SCRAPING_DELAY_SECONDS=2
API_NEWS_KEY=YOUR_NEWS_API_KEY_HERE

# === Green IT / CodeCarbon ===
CODECARBON_ENABLED=true
CODECARBON_OUTPUT_DIR=./logs/carbon

# === DVC Remote ===
DVC_REMOTE_URL=s3://clean-data
DVC_REMOTE_ENDPOINT=http://localhost:9000
