{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Logs totaux",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"greentech\"}[$__range]))",
          "queryType": "instant",
          "legendFormat": "Logs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short"
        }
      }
    },
    {
      "title": "Erreurs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"greentech\", level=\"error\"}[$__range]))",
          "queryType": "instant",
          "legendFormat": "Erreurs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Warnings",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"greentech\", level=\"warning\"}[$__range]))",
          "queryType": "instant",
          "legendFormat": "Warnings"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Modules actifs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count(sum by (module) (count_over_time({job=\"greentech\"}[$__range])))",
          "queryType": "instant",
          "legendFormat": "Modules"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "unit": "short"
        }
      }
    },
    {
      "title": "Volume de logs par niveau",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({job=\"greentech\"}[$__auto]))",
          "queryType": "range",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 30,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ]
          },
          {
            "matcher": { "id": "byName", "options": "warning" },
            "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } } ]
          },
          {
            "matcher": { "id": "byName", "options": "info" },
            "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ]
          }
        ]
      }
    },
    {
      "title": "Activite par module (top 8)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "topk(8, sum by (module) (count_over_time({job=\"greentech\"}[$__auto])))",
          "queryType": "range",
          "legendFormat": "{{module}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Repartition des logs par niveau",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({job=\"greentech\"}[$__range]))",
          "queryType": "instant",
          "legendFormat": "{{level}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "right", "values": ["value"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false }
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ]
          },
          {
            "matcher": { "id": "byName", "options": "warning" },
            "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } } ]
          },
          {
            "matcher": { "id": "byName", "options": "info" },
            "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ]
          }
        ]
      }
    },
    {
      "title": "Volume de logs par module (top 12)",
      "type": "table",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "topk(12, sum by (module) (count_over_time({job=\"greentech\"}[$__range])))",
          "queryType": "instant",
          "legendFormat": "{{module}}"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true } } }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "align": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Logs" },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
              { "id": "color", "value": { "mode": "continuous-GrYlRd" } }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm" }
    },
    {
      "title": "Logs Applicatifs (Loki)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"greentech\"}",
          "queryType": "range",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "wrapLogMessage": true
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["greentech", "performance", "logs"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "GreenTech - Performance Systeme",
  "uid": "greentech-perf",
  "version": 2
