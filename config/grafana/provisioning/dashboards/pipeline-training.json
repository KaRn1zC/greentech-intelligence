{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Fold en cours",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "greentech_training_fold_current", "legendFormat": "{{run_name}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "green", "value": 5 }
            ]
          }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "title": "MCC moyenne (CV)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "greentech_training_cv_mcc_mean", "legendFormat": "{{run_name}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 4,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        }
      }
    },
    {
      "title": "Ecart-type MCC (stabilite CV)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "greentech_training_cv_mcc_std", "legendFormat": "{{run_name}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 4,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.15 }
            ]
          }
        }
      },
      "options": { "colorMode": "value", "graphMode": "none" }
    },
    {
      "title": "Derniere activite training (secondes)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "time() - greentech_training_last_push_timestamp_seconds", "legendFormat": "{{run_name}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 600 }
            ]
          }
        }
      }
    },
    {
      "title": "MCC par fold (Qwen3 vs mDeBERTa)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "greentech_training_fold_mcc", "legendFormat": "Fold {{fold}} ({{run_name}})" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 4,
          "custom": { "drawStyle": "line", "lineWidth": 2, "pointSize": 6 }
        }
      }
    },
    {
      "title": "F1 et Recall par fold",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "greentech_training_fold_f1", "legendFormat": "F1 fold {{fold}}" },
        { "expr": "greentech_training_fold_recall", "legendFormat": "Recall fold {{fold}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 4,
          "custom": { "drawStyle": "line", "lineWidth": 2, "pointSize": 6 }
        }
      }
    },
    {
      "title": "Duree par fold",
      "type": "bargauge",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "greentech_training_fold_duration_seconds", "legendFormat": "Fold {{fold}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "continuous-BlPu" }
        }
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "title": "Memoire GPU (PyTorch)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "greentech_training_gpu_memory_allocated_bytes", "legendFormat": "Alloue" },
        { "expr": "greentech_training_gpu_memory_reserved_bytes", "legendFormat": "Reserve" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Baseline zero-shot - MCC",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "greentech_baseline_mcc", "legendFormat": "{{model}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 4,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "green", "value": 0.3 }
            ]
          }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "title": "Baseline zero-shot - F1",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "greentech_baseline_f1", "legendFormat": "{{model}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 4,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "green", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "title": "Baseline zero-shot - Recall Green IT",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "greentech_baseline_recall", "legendFormat": "{{model}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 4,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "title": "Baseline - Derniere mise a jour",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "time() - greentech_baseline_last_push_timestamp_seconds", "legendFormat": "{{model}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 86400 },
              { "color": "red", "value": 604800 }
            ]
          }
        }
      }
    },
    {
      "title": "CO2eq cumule (tous entrainements)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "last_over_time(greentech_training_emissions_grams_grand_total[30d])",
          "legendFormat": "Total CO2eq",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "massg",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "title": "CO2eq par famille de modele",
      "type": "bargauge",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "last_over_time(greentech_training_emissions_grams_total[30d])",
          "legendFormat": "{{model_type}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "massg",
          "decimals": 2,
          "color": { "mode": "continuous-GrYlRd" }
        }
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "title": "Nombre de runs traces (CodeCarbon)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(last_over_time(greentech_training_emissions_runs_count[30d]))",
          "legendFormat": "Runs traces",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Dernier rejeu MLflow -> Pushgateway",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "time() - max(last_over_time(greentech_training_emissions_last_export_timestamp_seconds[30d]))",
          "legendFormat": "Age du snapshot",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 86400 },
              { "color": "red", "value": 604800 }
            ]
          }
        }
      }
    },
    {
      "title": "Empreinte carbone par run (CodeCarbon)",
      "type": "bargauge",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(15, last_over_time(greentech_training_emissions_grams[30d]))",
          "legendFormat": "{{run_name}} - {{model_type}} ({{phase}})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "massg",
          "decimals": 3,
          "color": { "mode": "continuous-BlYlRd" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "lcd",
        "showUnfilled": true
      }
    },
    {
      "title": "Logs pipeline et training (Loki)",
      "type": "logs",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 39 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"greentech\"} | json | module =~ \"retrain_pipeline|training|baseline|auto_annotate_dataset|classify_candidates|summarizer|scraper\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["greentech", "pipeline", "training"],
  "templating": { "list": [] },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Pipeline & Training",
  "uid": "greentech-pipeline-training",
  "version": 6,
  "weekStart": ""
}
